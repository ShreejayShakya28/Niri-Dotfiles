#!/usr/bin/env bash

# set -uo pipefail but not -e: errors are handled manually via cp_file/cp_glob
# so we get full control over pass/fail tracking without surprise exits
set -uo pipefail

# resolve real script location, symlink-safe
# note: readlink -f is GNU coreutils only (not available on macOS without greadlink)
REPO_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
CONFIG="$HOME/.config"

GREEN='\033[0;32m'
BLUE='\033[0;34m'
RED='\033[0;31m'
YELLOW='\033[0;33m'
NC='\033[0m'

log()  { echo -e "${BLUE}::${NC} $1"; }
ok()   { echo -e "  ${GREEN}ok${NC} $1";   PASS=$((PASS + 1)); }
fail() { echo -e "  ${RED}fail${NC} $1";   FAIL=$((FAIL + 1)); }
warn() { echo -e "  ${YELLOW}warn${NC} $1"; }

PASS=0
FAIL=0
DRY_RUN=false
BACKUP=false
YES=false

usage() {
  echo "usage: ./dot [options] <push|pull> <app|all>"
  echo ""
  echo "  push  deploy from repo → ~/.config  (install)"
  echo "  pull  harvest from ~/.config → repo  (save)"
  echo ""
  echo "  apps: fuzzel waybar foot niri tmux"
  echo ""
  echo "  options:"
  echo "    -n    dry run (print what would be copied, no changes)"
  echo "    -b    backup existing files before overwriting (.bak)"
  echo "          note: on pull, this backs up repo files not system files"
  echo "                git is your real backup for repo files"
  echo "    -y    skip confirmation prompt (for scripted use)"
  echo ""
  echo "  examples:"
  echo "    ./dot push all        deploy everything to system"
  echo "    ./dot pull waybar     save waybar edits back to repo"
  echo "    ./dot -n pull all     preview what pull would collect"
  echo "    ./dot -y push all     deploy without prompt"
  exit 1
}

while getopts "nby" opt; do
  case $opt in
    n) DRY_RUN=true ;;
    b) BACKUP=true  ;;
    y) YES=true     ;;
    *) usage        ;;
  esac
done
shift $((OPTIND - 1))

[[ $# -lt 2 ]] && usage

DIRECTION="${1}"
APP="${2}"

[[ "$DIRECTION" != "push" && "$DIRECTION" != "pull" ]] && usage

cp_file() {
  local src="$1" dst="$2"

  if [[ ! -f "$src" ]]; then
    fail "$src (source missing)"
    return
  fi

  local dst_dir
  dst_dir="$(dirname "$dst")"
  if [[ ! -d "$dst_dir" ]]; then
    fail "$dst (destination dir $dst_dir does not exist)"
    return
  fi

  if $DRY_RUN; then
    warn "dry-run: $src → $dst"
    return
  fi

  if $BACKUP && [[ -f "$dst" ]]; then
    if ! cp -p "$dst" "${dst}.bak"; then
      fail "could not backup $dst — skipping"
      return
    fi
    warn "backed up ${dst}.bak"
  fi

  if cp -p "$src" "$dst"; then
    ok "$(basename "$dst")"
  else
    fail "$(basename "$dst")"
  fi
}

cp_glob() {
  local pattern="$1" dst_dir="$2"

  if [[ ! -d "$dst_dir" ]]; then
    fail "$dst_dir (destination dir does not exist)"
    return
  fi

  shopt -s nullglob
  local files=($pattern)
  shopt -u nullglob

  if [[ ${#files[@]} -eq 0 ]]; then
    warn "no files matched: $pattern"
    return
  fi

  for src in "${files[@]}"; do
    cp_file "$src" "$dst_dir/$(basename "$src")"
  done
}

# --- push: repo → system ---

push_fuzzel() {
  log "push fuzzel"
  cp_file "$REPO_DIR/fuzzel/fuzzel.ini" "$CONFIG/fuzzel/fuzzel.ini"
}

push_waybar() {
  log "push waybar"
  cp_file "$REPO_DIR/waybar/config.jsonc" "$CONFIG/waybar/config.jsonc"
  cp_file "$REPO_DIR/waybar/style.css"    "$CONFIG/waybar/style.css"
  # note: push only deploys scripts tracked in the repo
  cp_glob "$REPO_DIR/waybar/scripts/*.sh" "$CONFIG/waybar/scripts"
}

push_foot() {
  log "push foot"
  cp_file "$REPO_DIR/foot/foot.ini" "$CONFIG/foot/foot.ini"
}

push_niri() {
  log "push niri"
  cp_file "$REPO_DIR/niri/config.kdl" "$CONFIG/niri/config.kdl"
}

push_tmux() {
  log "push tmux"
  cp_file "$REPO_DIR/tmux/tmux.conf" "$HOME/.tmux.conf"
}

# --- pull: system → repo ---

pull_fuzzel() {
  log "pull fuzzel"
  cp_file "$CONFIG/fuzzel/fuzzel.ini" "$REPO_DIR/fuzzel/fuzzel.ini"
}

pull_waybar() {
  log "pull waybar"
  cp_file "$CONFIG/waybar/config.jsonc" "$REPO_DIR/waybar/config.jsonc"
  cp_file "$CONFIG/waybar/style.css"    "$REPO_DIR/waybar/style.css"
  # note: pull harvests ALL .sh scripts from system — including any added locally
  # review with git diff before committing to avoid importing unintended scripts
  cp_glob "$CONFIG/waybar/scripts/*.sh" "$REPO_DIR/waybar/scripts"
}

pull_foot() {
  log "pull foot"
  cp_file "$CONFIG/foot/foot.ini" "$REPO_DIR/foot/foot.ini"
}

pull_niri() {
  log "pull niri"
  cp_file "$CONFIG/niri/config.kdl" "$REPO_DIR/niri/config.kdl"
}

pull_tmux() {
  log "pull tmux"
  cp_file "$HOME/.tmux.conf" "$REPO_DIR/tmux/tmux.conf"
}

# --- dispatch ---

run_app() {
  local dir="$1" app="$2"

  # self-validate direction so this function is safe regardless of how it's called
  [[ "$dir" == "push" || "$dir" == "pull" ]] || { fail "invalid direction: $dir"; exit 1; }

  # warn if -b is used on pull — git is the real backup for repo files
  if $BACKUP && [[ "$dir" == "pull" ]]; then
    warn "-b on pull backs up repo files, not system files — git is your real backup here"
  fi

  case "$app" in
    fuzzel) ${dir}_fuzzel ;;
    waybar) ${dir}_waybar ;;
    foot)   ${dir}_foot   ;;
    niri)   ${dir}_niri   ;;
    tmux)   ${dir}_tmux   ;;
    all)
      if ! $DRY_RUN && ! $YES; then
        read -r -p "${dir} all dotfiles? [y/N] " confirm
        [[ "$confirm" =~ ^[Yy]$ ]] || { echo "aborted."; exit 0; }
      fi
      ${dir}_fuzzel
      ${dir}_waybar
      ${dir}_foot
      ${dir}_niri
      ${dir}_tmux
      ;;
    *) usage ;;
  esac
}

run_app "$DIRECTION" "$APP"

echo ""
echo -e "  done — ${GREEN}${PASS} ok${NC} / ${RED}${FAIL} failed${NC}"
[[ $FAIL -gt 0 ]] && exit 1 || exit 0
